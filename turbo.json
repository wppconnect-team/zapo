{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "test": {
            "dependsOn": ["build"],
            "passThroughEnv": [
                "ZAPO_TEST_MYSQL_HOST",
                "ZAPO_TEST_MYSQL_PORT",
                "ZAPO_TEST_MYSQL_USER",
                "ZAPO_TEST_MYSQL_PASSWORD",
                "ZAPO_TEST_MYSQL_DATABASE",
                "ZAPO_TEST_PG_HOST",
                "ZAPO_TEST_PG_PORT",
                "ZAPO_TEST_PG_USER",
                "ZAPO_TEST_PG_PASSWORD",
                "ZAPO_TEST_PG_DATABASE",
                "ZAPO_TEST_REDIS_HOST",
                "ZAPO_TEST_REDIS_PORT",
                "ZAPO_TEST_MONGO_HOST",
                "ZAPO_TEST_MONGO_PORT"
            ]
        },
        "lint": {},
        "typecheck": {
            "inputs": [
                "$TURBO_DEFAULT$",
                "$TURBO_ROOT$/src/**/*.ts",
                "$TURBO_ROOT$/tsconfig.base.json",
                "$TURBO_ROOT$/packages/tsconfig.paths.json",
                "$TURBO_ROOT$/proto/**/*.ts",
                "$TURBO_ROOT$/proto/**/*.d.ts"
            ]
        }
    }
}

{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": false,
        "sourceMap": false,
        "noEmit": true
    }
}

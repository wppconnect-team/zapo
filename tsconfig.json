{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "baseUrl": ".",
        "paths": {
            "zapo-js": ["src"],
            "zapo-js/store": ["src/store"],
            "zapo-js/signal": ["src/signal"],
            "zapo-js/auth": ["src/auth"],
            "zapo-js/appstate": ["src/appstate"],
            "zapo-js/retry": ["src/retry"],
            "zapo-js/proto": ["src/proto"],
            "zapo-js/protocol": ["src/protocol"],
            "zapo-js/crypto": ["src/crypto"],
            "zapo-js/media": ["src/media"],
            "zapo-js/util": ["src/util"],
            "zapo-js/transport": ["src/transport"],
            "@appstate": ["src/appstate"],
            "@appstate/*": ["src/appstate/*"],
            "@appstate-spec": ["src/appstate-spec"],
            "@auth": ["src/auth"],
            "@auth/*": ["src/auth/*"],
            "@client": ["src/client"],
            "@client/*": ["src/client/*"],
            "@crypto": ["src/crypto"],
            "@crypto/*": ["src/crypto/*"],
            "@infra/*": ["src/infra/*"],
            "@media": ["src/media"],
            "@media/*": ["src/media/*"],
            "@message": ["src/message"],
            "@message/*": ["src/message/*"],
            "@protocol": ["src/protocol"],
            "@protocol/*": ["src/protocol/*"],
            "@proto": ["src/proto"],
            "@mex": ["src/mex"],
            "@retry": ["src/retry"],
            "@retry/*": ["src/retry/*"],
            "@signal": ["src/signal"],
            "@signal/*": ["src/signal/*"],
            "@store": ["src/store"],
            "@store/*": ["src/store/*"],
            "@transport": ["src/transport"],
            "@transport/*": ["src/transport/*"],
            "@util/*": ["src/util/*"],
            "@version-spec": ["src/version-spec"],
            "@zapo-js/*": ["packages/*/src"]
        },
        "strict": true,
        "declaration": true,
        "sourceMap": false,
        "outDir": "dist",
        "rootDir": "src",
        "lib": ["ES2020"],
        "types": ["node"],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*"],
    "exclude": ["dist", "node_modules"]
}
